<tr>
  <td>
    <divv class="d-flex justify-content-center">
      <div class="rounded-2 border" style="width: 45px; height: 45px; background-color: <%= spool.filament.color_hex %>">&nbsp;</div>
    </div>
  </td>
  <td>
    <p class="my-0">
      <strong>
        <%= spool.filament.product.brand.name %>
        &middot;
        <%= spool.filament.product.material.name %>
        <%= spool.filament.product.variant.name %>
      </strong>
    </p>
    <p class="my-0 text-muted small">
      <%= spool.filament.product.diameter %> mm
      &middot;
      <%= spool.filament.color_name %>
    </p>
  </td>
  <td>
    <span class="badge pill text-bg-dark font-monospace inventory-tag"><%= spool.inventory_tag %></span>
    <% if (number_of_spools = spool.number_of_same_filament) != 1 %>
      <span class="badge pill text-bg-info"><%= pluralize number_of_spools, "spool" %></span>
    <% end %>
    <% if spool.ovp? %>
      <span class="badge pill text-bg-success">OVP</span>
    <% end %>
    <% if spool.refill_only? %>
      <span class="badge pill text-bg-danger">Refill</span>
    <% end %>
  </td>
  <td>
    <% percent = ((spool.remaining_weight_grams.to_f / spool.filament.product.weight_grams) * 100).floor.clamp(0, 100) %>
    <small class="my-0 text-muted">
      <%= number_with_delimiter spool.remaining_weight_grams %> g / <%= number_with_delimiter spool.filament.product.weight_grams %> g
    </small>
    <div class="progress" role="progressbar" aria-label="Progress bar" aria-valuenow="<%= percent %>" aria-valuemin="0" aria-valuemax="100">
      <div class="progress-bar progress-bar-striped bg-dark" style="width: <%= percent %>%"></div>
    </div>
  </td>
  <td>
    <div class="dropdown d-flex justify-content-center">
      <button class="btn btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-gear-fill" viewBox="0 0 16 16">
          <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
        </svg>
      </button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li><%= link_to "Edit", edit_spool_path(spool), class: ["dropdown-item", "disabled": !user_signed_in?], data: { turbo_frame: "modal" } %></li>
        <li><%= link_to "Delete", spool_path(spool), class: ["dropdown-item", "disabled": !user_signed_in?], data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %></li>
      </ul>
    </div>
  </td>
</tr>
